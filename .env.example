# Example environment configuration for MiniStore Backend
# Copy this to .env and modify values as needed

# Server Configuration
PORT=3001
NODE_ENV=development

# Turso Database Configuration
# Option 1: Local SQLite (default)
TURSO_CONNECTION_URL=file:local.db
TURSO_AUTH_TOKEN=

# Option 2: Turso Cloud
# TURSO_CONNECTION_URL=libsql://your-database-name.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOiJFZEdTNTEyIiwidHlwIjoiSldUIn0...

# Security - Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Default Login Credentials (operator account)
# Username: operator
# Password: developer2510
